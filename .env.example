# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=exocortex
POSTGRES_PASSWORD=change_me_strong_password

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_strong_password
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=exocortex
KEYCLOAK_CLIENT_ID=exocortex-api

# ─── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006"]

# ─── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=exocortex-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_strong_password

# ─── AI Providers (Phase 6) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_BUDGET_DAILY_USD=10.00

# ─── Stripe / Deposit (Phase 8) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Calendar Integrations (Phase 9) ───────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ─── Telegram Bot (Phase 9) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Web / Frontend (Phase 10) ─────────────────────────────────────────────────
# Required for NextAuth.js — generate: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl
# Keycloak confidential client secret for NextAuth.
# Matches the placeholder secret pre-set in infrastructure/keycloak/realm-export.json.
# Rotate via Keycloak Admin → Clients → exocortex-frontend → Credentials → Regenerate.
KEYCLOAK_FRONTEND_CLIENT_SECRET=CHANGE_ME_frontend_secret_rotate_after_first_login

# ─── Encryption (REQUIRED) ─────────────────────────────────────────────────────
# Fernet key for encrypting API keys and secrets stored in the DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EXOCORTEX_SECRET_KEY=change_me_generate_with_fernet_command_above

# NOTE: AI keys (Anthropic, OpenAI, Stripe, Telegram) are entered in the Admin UI
# after first launch (Admin → Settings). The entries below are NOT used.
