# ═══════════════════════════════════════════════════════════════════════════════
# ExoCortex — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   cp .env.production.example .env
#   nano .env   ← fill in every value marked CHANGE_ME
#   docker-compose -f docker-compose.prod.yml up -d
#
# AI keys, Stripe keys, Telegram token, and agent prompts are NOT here.
# Enter them in the Admin UI after first launch:
#   https://YOUR_DOMAIN/admin/settings
#
# ─── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# Public base URL — used for OAuth callbacks (Google Calendar, Microsoft Graph) and webhook URLs.
# Must match the domain in Nginx. Do NOT add api. subdomain — the /api/ path is served from main domain.
BASE_URL=https://yourdomain.com

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=exocortex
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# ─── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# ─── Application secrets ────────────────────────────────────────────────────────
# Encryption key for SystemConfig secrets (exactly 32 chars — URL-safe base64 32 bytes)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EXOCORTEX_SECRET_KEY=CHANGE_ME_generate_with_fernet_command_above

# NextAuth.js signing secret
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl

# Keycloak confidential client secret for NextAuth.
# Pre-set in realm-export.json — copy the value exactly as-is for first deploy.
# IMPORTANT: rotate after first login via Keycloak Admin → Clients → exocortex-frontend
# → Credentials → Regenerate Secret, then update this value and restart frontend.
KEYCLOAK_FRONTEND_CLIENT_SECRET=CHANGE_ME_frontend_secret_rotate_after_first_login

# ─── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_use_openssl_rand_base64_16

# ─── Sentry (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable error tracking entirely.
# Get DSN at sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=

# ─── SMTP / Email (optional env fallback — prefer Admin UI) ────────────────────
# These can be set here as a bootstrap fallback.
# PREFERRED: enter them in the Admin UI after first launch (Admin UI → Email / SMTP).
# The Admin UI values take priority over these env vars.
#
# Leave all blank to disable email sending entirely (team invitations silently skipped).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ─── NOT HERE: AI / Stripe / Telegram / Calendar OAuth / Agent Prompts ─────────
# These are entered in the Admin UI after first launch.
# Path: https://YOUR_DOMAIN/admin/settings
#
# Supported keys (set via UI):
#   anthropic_api_key             — Anthropic Claude API
#   openai_api_key                — OpenAI GPT API
#   stripe_secret_key             — Stripe secret key (sk_live_...)
#   stripe_webhook_secret         — Stripe webhook signature (whsec_...)
#   stripe_price_id_pro           — Stripe Price ID for Pro plan (price_...)
#   stripe_price_id_team          — Stripe Price ID for Team plan (price_...)
#   telegram_bot_token            — Telegram bot
#   google_calendar_client_id     — Google OAuth2 client ID (Calendar)
#   google_calendar_client_secret — Google OAuth2 client secret (Calendar)
#   ms_graph_client_id            — Microsoft Graph OAuth2 client ID (Calendar)
#   ms_graph_client_secret        — Microsoft Graph OAuth2 client secret (Calendar)
#   vapid_private_key             — Web Push VAPID private key
#   vapid_public_key              — Web Push VAPID public key
#   smtp_host / smtp_port / smtp_username / smtp_password / smtp_from_email / smtp_use_tls
#   agent_prompt_*                — Per-persona system prompts
