# ── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── Keycloak (Auth) ───────────────────────────────────────────────────────────
# These are infra secrets — set once during deployment
KEYCLOAK_CLIENT_ID=exocortex-frontend
KEYCLOAK_CLIENT_SECRET=from-keycloak-admin-panel
KEYCLOAK_ISSUER=http://localhost:8080/realms/exocortex

# ── Backend ───────────────────────────────────────────────────────────────────
# Internal URL for server-side API calls (Next.js → FastAPI inside Docker)
BACKEND_URL=http://backend:8000
# Public URL used for OpenGraph, webhooks, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: AI keys (Anthropic, OpenAI, Stripe, Telegram) are configured
# in the Admin UI → Settings page — NOT here.
